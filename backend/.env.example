# App
APP_NAME=pyMC_Glass API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_LOG_LEVEL=INFO

# Data plane
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/pymc_glass
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=8883
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=
MQTT_BASE_TOPIC=glass
MQTT_TLS_ENABLED=true
MQTT_TLS_CA_CERT=/app/data/pki/ca.crt.pem
MQTT_TLS_CLIENT_CERT=/app/data/pki/mqtt-backend-client.crt.pem
MQTT_TLS_CLIENT_KEY=/app/data/pki/mqtt-backend-client.key.pem
MQTT_TLS_INSECURE=false
MQTT_REPEATER_TLS_ENABLED=true
MQTT_INGEST_ENABLED=true
MQTT_INGEST_QUEUE_MAXSIZE=2000
PKI_STATE_DIR=/app/data/pki
PKI_CA_COMMON_NAME=pyMC_Glass Local CA
PKI_CA_VALID_DAYS=3650
PKI_CLIENT_CERT_VALID_DAYS=90
PKI_RENEW_BEFORE_DAYS=30

# Auth
AUTH_TOKEN_TTL_MINUTES=1440
AUTH_TOKEN_BYTES=48
AUTH_PASSWORD_MIN_LENGTH=12
BOOTSTRAP_SEED_ADMIN_ENABLED=true
BOOTSTRAP_SEED_ADMIN_EMAIL=admin@pymc.glass
BOOTSTRAP_SEED_ADMIN_PASSWORD=admin12345678
BOOTSTRAP_SEED_ADMIN_DISPLAY_NAME=Admin
ALERT_POLICY_MONITOR_ENABLED=true
ALERT_POLICY_MONITOR_INTERVAL_SECONDS=60

# Contract version selector
CONTRACT_VERSION=v1

